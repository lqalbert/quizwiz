/**
 * QuizWiz 全局样式 — 极简 / 类 iOS
 * 页背景 #F8F9FB · 卡片 #FFFFFF · 主色 #0066FF · 正文 #1A1A1A · 辅助 #757575
 */

page {
  background-color: #f8f9fb;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  letter-spacing: 0.02em;
  box-sizing: border-box;
}

/* 微信默认 primary 为绿，统一为主色蓝 */
button[type='primary'] {
  background-color: #0066ff !important;
  color: #fff !important;
  border: none !important;
  font-weight: 600;
}

button[type='primary']::after {
  border: none !important;
}

button[type='primary'][disabled] {
  opacity: 0.45 !important;
}

/* 默认按钮：浅底，字主色 */
button[type='default'] {
  background-color: #f0f2f5 !important;
  color: #1a1a1a !important;
  border: none !important;
}

button[type='default']::after {
  border: none !important;
}
