<wxs module="util">
function join(arr, sep) {
  if (!arr || arr.length === 0) return '';
  var s = arr[0];
  for (var i = 1; i < arr.length; i++) {
    s = s + sep + arr[i];
  }
  return s;
}
module.exports.join = join;
</wxs>

<view class="container">
  <view class="header">
    <text class="title">题目收藏</text>
    <button size="mini" bindtap="onStartFavoritePractice">收藏练习</button>
  </view>

  <view class="filters">
    <view class="filter-item">
      <text class="label">学科</text>
      <picker mode="selector" range="{{subjects}}" range-key="name" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-view">{{subjects.length > 0 ? subjects[subjectIndex].name : '加载中...'}}</view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="label">练习题量</text>
      <slider min="1" max="20" step="1" show-value value="{{limit}}" bindchange="onLimitChange" />
    </view>
    <button size="mini" bindtap="onApplyFilter" loading="{{loading}}">应用筛选</button>
  </view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无收藏，在练习页点击题旁的星标即可收藏。</view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card">
      <text class="stem">{{index + 1}}. {{item.stem}}</text>
      <text class="meta">学科：{{util.join(item.subjects, '、') || '未设置'}}｜章节：{{item.chapter || '未设置'}}</text>
      <button class="remove-btn" size="mini" plain="true" data-qid="{{item.questionId}}" bindtap="onRemoveFavorite">
        取消收藏
      </button>
    </view>
  </block>
</view>
