/* 题目收藏 */

.container {
  min-height: 100vh;
  background: #f8f9fb;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.header button {
  margin: 0 !important;
  background: #ffffff !important;
  color: #0066ff !important;
  border-radius: 999rpx !important;
  border: 1rpx solid #e8eaed !important;
  font-weight: 500 !important;
}

.header button::after {
  border: none !important;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}

.filters {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filters button {
  margin-top: 12rpx !important;
  border-radius: 999rpx !important;
  font-weight: 600 !important;
}

.filters button::after {
  border: none !important;
}

.filter-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #757575;
  font-size: 26rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.picker-view {
  background: #f3f5f8;
  border: 1rpx solid #e8eaed;
  border-radius: 20rpx;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.error {
  color: #d92d20;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: #fef3f2;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.empty {
  color: #757575;
  margin-top: 48rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.6;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stem {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #1a1a1a;
  line-height: 1.45;
}

.meta {
  display: block;
  color: #757575;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.remove-btn {
  margin-top: 8rpx !important;
  border-radius: 999rpx !important;
  background: #fff !important;
  color: #757575 !important;
  border: 1rpx solid #e8eaed !important;
}

.remove-btn::after {
  border: none !important;
}
