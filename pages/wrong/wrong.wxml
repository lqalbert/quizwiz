<wxs module="util">
function join(arr, sep) {
  if (!arr || arr.length === 0) return '';
  var s = arr[0];
  for (var i = 1; i < arr.length; i++) {
    s = s + sep + arr[i];
  }
  return s;
}
module.exports.join = join;
</wxs>

<view class="container">
  <view class="header">
    <text class="title">错题本</text>
    <button size="mini" bindtap="onStartWrongPractice">错题重练</button>
  </view>

  <view class="filters">
    <view class="filter-item">
      <text class="label">学科</text>
      <picker mode="selector" range="{{subjects}}" range-key="name" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-view">{{subjects.length > 0 ? subjects[subjectIndex].name : '加载中...'}}</view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="label">章节</text>
      <input class="input" placeholder="可选章节筛选" value="{{chapterInput}}" bindinput="onChapterInput" />
    </view>
    <view class="row">
      <view class="filter-item half">
        <text class="label">状态</text>
        <picker mode="selector" range="{{masteredOptions}}" value="{{masteredIndex}}" bindchange="onMasteredChange">
          <view class="picker-view">{{masteredOptions[masteredIndex]}}</view>
        </picker>
      </view>
      <view class="filter-item half">
        <text class="label">重练题量</text>
        <slider min="1" max="20" step="1" show-value value="{{limit}}" bindchange="onLimitChange" />
      </view>
    </view>
    <button size="mini" bindtap="onApplyFilter" loading="{{loading}}">应用筛选</button>
  </view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无错题，继续保持！</view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card">
      <text class="stem">{{index + 1}}. {{item.stem}}</text>
      <text class="meta">学科：{{util.join(item.subjects, '、') || '未设置'}}｜章节：{{item.chapter || '未设置'}}</text>
      <text class="meta">错误次数：{{item.wrongCount}}｜答案：{{util.join(item.answerLetters, ',')}}</text>
      <text wx:if="{{item.analysis}}" class="analysis">解析：{{item.analysis}}</text>
      <button class="mark-btn" size="mini" type="primary" plain="true" data-id="{{item.id}}" bindtap="onMarkMastered">
        标记已掌握
      </button>
    </view>
  </block>
</view>
