<wxs module="util">
function join(arr, sep) {
  if (!arr || arr.length === 0) return '';
  var s = arr[0];
  for (var i = 1; i < arr.length; i++) {
    s = s + sep + arr[i];
  }
  return s;
}
module.exports.join = join;
</wxs>

<view class="container">
  <view class="header">
    <text class="title">错题本</text>
    <button size="mini" bindtap="loadWrongQuestions" loading="{{loading}}">刷新</button>
  </view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无错题，继续保持！</view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card">
      <text class="stem">{{index + 1}}. {{item.stem}}</text>
      <text class="meta">学科：{{util.join(item.subjects, '、') || '未设置'}}｜章节：{{item.chapter || '未设置'}}</text>
      <text class="meta">错误次数：{{item.wrongCount}}｜答案：{{util.join(item.answerLetters, ',')}}</text>
      <text wx:if="{{item.analysis}}" class="analysis">解析：{{item.analysis}}</text>
      <button class="mark-btn" size="mini" type="primary" plain="true" data-id="{{item.id}}" bindtap="onMarkMastered">
        标记已掌握
      </button>
    </view>
  </block>
</view>
