/* 错题本 */

.container {
  min-height: 100vh;
  background: #f8f9fb;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.header button {
  margin: 0 !important;
  background: #ffffff !important;
  color: #0066ff !important;
  border-radius: 999rpx !important;
  border: 1rpx solid #e8eaed !important;
  font-weight: 500 !important;
}

.header button::after {
  border: none !important;
}

.filters {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filters button {
  margin-top: 12rpx !important;
  border-radius: 999rpx !important;
  font-weight: 600 !important;
}

.filters button::after {
  border: none !important;
}

.filter-item {
  margin-bottom: 20rpx;
}

.filter-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-direction: row;
}

.filter-switch .label {
  margin-bottom: 0;
}

.row {
  display: flex;
  gap: 16rpx;
}

.half {
  flex: 1;
}

.label {
  display: block;
  color: #757575;
  font-size: 26rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.picker-view,
.input {
  background: #f3f5f8;
  border: 1rpx solid #e8eaed;
  border-radius: 20rpx;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}

.error {
  color: #d92d20;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: #fef3f2;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.empty {
  color: #757575;
  margin-top: 48rpx;
  text-align: center;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stem-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.tag-priority {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff8a3d 0%, #ff6b35 100%);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  line-height: 1.3;
  font-weight: 600;
}

.stem {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
}

.meta,
.analysis {
  display: block;
  color: #757575;
  font-size: 24rpx;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  align-items: center;
}

.mark-btn,
.priority-toggle-btn {
  margin-top: 0 !important;
  border-radius: 999rpx !important;
}

.mark-btn[type='primary'] {
  box-shadow: none !important;
}

.priority-toggle-btn {
  background: #fff !important;
  color: #0066ff !important;
  border: 1rpx solid #e8eaed !important;
}

.priority-toggle-btn::after,
.mark-btn::after {
  border: none !important;
}
