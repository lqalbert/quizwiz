/* 登录页 — 极简居中 · 克莱因蓝主按钮 */

.wrap {
  min-height: 100vh;
  padding: 120rpx 48rpx 80rpx;
  box-sizing: border-box;
  background: #f8f9fb;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  letter-spacing: -0.03em;
}

.sub {
  font-size: 30rpx;
  color: #757575;
  margin-bottom: 20rpx;
  line-height: 1.5;
  text-align: center;
}

.explain {
  font-size: 26rpx;
  color: #9e9e9e;
  margin-bottom: 56rpx;
  line-height: 1.55;
  text-align: center;
  max-width: 560rpx;
}

.error {
  width: 100%;
  max-width: 560rpx;
  background: #fef3f2;
  color: #c41e1e;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100% !important;
  max-width: 560rpx !important;
  margin-top: 16rpx !important;
  border-radius: 999rpx !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 12rpx 32rpx rgba(0, 102, 255, 0.28) !important;
}

.login-btn::after {
  border: none !important;
}

.secondary-btn {
  margin-top: 24rpx;
  background: #fff !important;
  color: #0066ff !important;
  border: 2rpx solid #e8eaed !important;
}

.secondary-btn::after {
  border: none !important;
}

.hint {
  margin-top: 56rpx;
  font-size: 22rpx;
  color: #9e9e9e;
  line-height: 1.65;
  text-align: center;
  max-width: 560rpx;
}
