/* 练习历史 */

.container {
  min-height: 100vh;
  background: #f8f9fb;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.header button {
  margin: 0 !important;
  background: #ffffff !important;
  color: #0066ff !important;
  border-radius: 999rpx !important;
  border: 1rpx solid #e8eaed !important;
  font-weight: 500 !important;
}

.header button::after {
  border: none !important;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}

.error {
  color: #d92d20;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: #fef3f2;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.empty {
  color: #757575;
  margin-top: 48rpx;
  text-align: center;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.row {
  display: block;
  color: #1a1a1a;
  font-size: 26rpx;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.label {
  color: #757575;
  font-weight: 500;
}

.detail-btn {
  margin-top: 16rpx !important;
  background: #f3f5f8 !important;
  color: #0066ff !important;
  border-radius: 999rpx !important;
  border: none !important;
  font-weight: 500 !important;
}

.detail-btn::after {
  border: none !important;
}

.priority-btn {
  margin-top: 12rpx !important;
  border-radius: 999rpx !important;
}

.priority-btn::after {
  border: none !important;
}

.details {
  margin-top: 16rpx;
  border-top: 1rpx solid #eef0f4;
  padding-top: 16rpx;
}

.detail-item {
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.ok {
  background: #e8f8ef;
  color: #0d7a3b;
}

.bad {
  background: #fef3f2;
  color: #c41e1e;
}
