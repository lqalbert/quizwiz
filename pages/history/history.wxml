<wxs module="util">
function join(arr, sep) {
  if (!arr || arr.length === 0) return '';
  var s = arr[0];
  for (var i = 1; i < arr.length; i++) {
    s = s + sep + arr[i];
  }
  return s;
}
function formatCostMs(ms) {
  if (ms === null || ms === undefined || ms === '') return '';
  var n = +ms;
  if (!n || n <= 0) return '';
  return (n / 1000).toFixed(1) + '秒';
}
module.exports.join = join;
module.exports.formatCostMs = formatCostMs;
</wxs>

<view class="container">
  <view class="header">
    <text class="title">练习历史</text>
    <button size="mini" bindtap="loadHistory" loading="{{loading}}">刷新</button>
  </view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无历史记录，先去做几题吧。</view>

  <block wx:for="{{list}}" wx:key="id" wx:for-item="session" wx:for-index="sidx">
    <view class="card">
      <text class="row"><text class="label">时间：</text>{{session.submittedAt || session.startedAt}}</text>
      <text class="row"><text class="label">模式：</text>{{session.mode}} ｜ <text class="label">学科：</text>{{session.subjectName || '未指定'}}</text>
      <text class="row"><text class="label">题量：</text>{{session.submittedCount}}/{{session.questionCount}}</text>
      <text class="row"><text class="label">得分：</text>{{session.correctCount}}/{{session.submittedCount}}（{{session.accuracy}}%）</text>
      <text class="row"><text class="label">状态：</text>{{session.status}}</text>
      <button
        class="detail-btn"
        size="mini"
        data-id="{{session.id}}"
        loading="{{detailLoadingId === session.id}}"
        bindtap="onToggleDetail"
      >
        {{detailMap[session.id] && detailMap[session.id].expanded ? '收起详情' : '查看详情'}}
      </button>

      <view wx:if="{{detailMap[session.id] && detailMap[session.id].expanded}}" class="details">
        <block wx:for="{{detailMap[session.id].details}}" wx:key="questionId" wx:for-item="detail" wx:for-index="didx">
          <view class="detail-item {{detail.isCorrect ? 'ok' : 'bad'}}">
            <text>{{didx + 1}}. {{detail.stem}}</text>
            <text>结果：{{detail.isCorrect ? '正确' : '错误'}}</text>
            <text>你的答案：{{util.join(detail.selectedLetters, ',')}}</text>
            <text>正确答案：{{util.join(detail.correctLetters, ',')}}</text>
            <text wx:if="{{util.formatCostMs(detail.costMs)}}">用时：{{util.formatCostMs(detail.costMs)}}</text>
            <text wx:if="{{detail.analysis}}">解析：{{detail.analysis}}</text>
            <button
              wx:if="{{!detail.isCorrect && detail.wrongId}}"
              class="priority-btn"
              size="mini"
              plain="true"
              data-wrong-id="{{detail.wrongId}}"
              data-session-id="{{session.id}}"
              data-question-id="{{detail.questionId}}"
              bindtap="onTogglePriority"
            >
              {{detail.isPriority ? '取消重点复习' : '加入重点复习'}}
            </button>
          </view>
        </block>
      </view>
    </view>
  </block>
</view>
