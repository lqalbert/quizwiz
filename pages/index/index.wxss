/* 练习首页 — 极简 iOS 风 · 主色 #0066FF */

.assignment-banner {
  background: #e8f1ff;
  color: #0066ff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 102, 255, 0.12);
}

.container {
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: #f8f9fb;
}

.header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 28rpx;
}

.header-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: flex-start;
}

.header-actions button {
  margin: 0 !important;
  background: #ffffff !important;
  color: #0066ff !important;
  font-size: 22rpx !important;
  font-weight: 500 !important;
  border-radius: 999rpx !important;
  padding: 0 24rpx !important;
  line-height: 52rpx !important;
  border: 1rpx solid #e8eaed !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.header-actions button::after {
  border: none !important;
}

.refresh-btn {
  margin: 0 !important;
}

.wrong-btn,
.history-btn,
.class-btn,
.fav-nav-btn {
  margin: 0 !important;
}

.stats-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stats-hint {
  display: block;
  font-size: 22rpx;
  color: #757575;
  margin-bottom: 20rpx;
  line-height: 1.45;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stats-cell {
  flex: 1;
  min-width: 0;
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: #757575;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.stats-main {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0066ff;
  margin-bottom: 6rpx;
  letter-spacing: -0.02em;
}

.stats-sub {
  display: block;
  font-size: 22rpx;
  color: #757575;
}

.stats-by-block {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef0f4;
}

.stats-by-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.stats-by-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.stats-by-name {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 12rpx;
}

.stats-by-num {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #0066ff;
  font-weight: 600;
}

.report-list-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.report-list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.report-list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.report-list-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.report-list-actions button {
  margin: 0 !important;
  background: #ffffff !important;
  color: #0066ff !important;
  border-radius: 999rpx !important;
  border: 1rpx solid #e8eaed !important;
  font-size: 22rpx !important;
}

.report-list-actions button::after {
  border: none !important;
}

.report-filter-picker {
  min-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e8eaed;
  border-radius: 999rpx;
  background: #f3f5f8;
  color: #1a1a1a;
  font-size: 22rpx;
  display: flex;
  align-items: center;
}

.report-refresh-btn {
  margin: 0 !important;
}

.report-list-empty {
  color: #757575;
  font-size: 26rpx;
}

.report-item {
  border-top: 1rpx solid #eef0f4;
  padding: 16rpx 0;
}

.report-item-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.report-item-status {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.status-open {
  background: #e8f1ff;
  color: #0066ff;
}

.status-reviewing {
  background: #fff4e6;
  color: #c45c00;
}

.status-closed {
  background: #e8f8ef;
  color: #0d7a3b;
}

.report-item-reason {
  font-size: 24rpx;
  color: #757575;
}

.report-item-stem {
  display: block;
  color: #1a1a1a;
  font-size: 26rpx;
  line-height: 1.45;
}

.report-item-note {
  display: block;
  color: #757575;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.filters {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filter-item {
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.half {
  flex: 1;
}

.filter-label {
  display: block;
  color: #757575;
  font-size: 26rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.filter-hint {
  display: block;
  font-size: 22rpx;
  color: #9e9e9e;
  margin-top: 12rpx;
  line-height: 1.5;
}

.picker-view,
.input {
  background: #f3f5f8;
  border: 1rpx solid #e8eaed;
  border-radius: 20rpx;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.error {
  margin-bottom: 20rpx;
  color: #d92d20;
  font-size: 26rpx;
  padding: 20rpx 24rpx;
  background: #fef3f2;
  border-radius: 20rpx;
}

.empty {
  color: #757575;
  padding: 40rpx 0;
  font-size: 28rpx;
  text-align: center;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.card-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.card-head-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.report-link {
  font-size: 24rpx;
  color: #0066ff;
  font-weight: 500;
  padding: 4rpx 8rpx;
}

.stem-in-card {
  flex: 1;
  min-width: 0;
}

.stem-text {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.45;
}

.fav-tap {
  flex-shrink: 0;
  padding: 4rpx 8rpx;
}

.fav-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #ffb020;
}

.stem {
  display: block;
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.meta {
  display: block;
  color: #757575;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.option {
  display: flex;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e8eaed;
  border-radius: 20rpx;
  background: #fff;
  transition: border-color 0.15s ease;
}

.option-selected {
  border-color: #0066ff;
  background: #f0f6ff;
}

.option-letter {
  width: 44rpx;
  color: #0066ff;
  font-weight: 700;
  font-size: 28rpx;
}

.option-text {
  flex: 1;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.45;
}

.submit-btn {
  margin: 32rpx 0 !important;
  border-radius: 999rpx !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 12rpx 32rpx rgba(0, 102, 255, 0.28);
}

.submit-btn::after {
  border: none !important;
}

.result {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}

.result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.result-time {
  display: block;
  font-size: 26rpx;
  color: #757575;
  margin-bottom: 16rpx;
}

.go-wrong-btn {
  margin: 0 0 20rpx 0 !important;
  background: #ffffff !important;
  color: #0066ff !important;
  border-radius: 999rpx !important;
  border: 1rpx solid #e8eaed !important;
  font-weight: 500 !important;
}

.go-wrong-btn::after {
  border: none !important;
}

.result-item {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.ok {
  background: #e8f8ef;
  color: #0d7a3b;
}

.bad {
  background: #fef3f2;
  color: #c41e1e;
}

.report-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 26, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  backdrop-filter: blur(4px);
}

.report-dialog {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.15);
}

.report-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #1a1a1a;
}

.report-picker {
  background: #f3f5f8;
  border: 1rpx solid #e8eaed;
  border-radius: 20rpx;
  padding: 22rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  color: #1a1a1a;
}

.report-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #e8eaed;
  border-radius: 20rpx;
  box-sizing: border-box;
  margin-bottom: 28rpx;
  background: #fafbfc;
}

.report-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.report-actions button {
  margin: 0 !important;
  border-radius: 999rpx !important;
}

.report-actions button[type='default'] {
  background: #f3f5f8 !important;
  color: #1a1a1a !important;
}
