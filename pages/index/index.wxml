<wxs module="util">
function hasLetter(selected, letter) {
  if (!selected || selected.length === 0) return false;
  for (var i = 0; i < selected.length; i++) {
    if (selected[i] === letter) return true;
  }
  return false;
}
function joinLetters(arr, sep) {
  if (!arr || arr.length === 0) return '';
  var s = arr[0];
  for (var i = 1; i < arr.length; i++) {
    s = s + sep + arr[i];
  }
  return s;
}
function formatSelected(arr) {
  var j = joinLetters(arr, ',');
  return j ? j : '未作答';
}
module.exports.hasLetter = hasLetter;
module.exports.joinLetters = joinLetters;
module.exports.formatSelected = formatSelected;
</wxs>

<view class="container">
  <view class="header">
    <text class="title">QuizWiz 练习模式</text>
    <view class="header-actions">
      <button class="wrong-btn" size="mini" bindtap="goWrongBook">错题本</button>
      <button class="refresh-btn" size="mini" bindtap="startPractice" loading="{{starting}}">开始练习</button>
    </view>
  </view>

  <view class="filters">
    <view class="filter-item">
      <text class="filter-label">学科</text>
      <picker mode="selector" range="{{subjects}}" range-key="name" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-view">{{subjects.length > 0 ? subjects[subjectIndex].name : '暂无学科'}}</view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="filter-label">章节</text>
      <input class="input" placeholder="可选，多个用逗号分隔" value="{{chapterInput}}" bindinput="onChapterInput" />
    </view>
    <view class="filter-row">
      <view class="filter-item half">
        <text class="filter-label">难度(1-5)</text>
        <input class="input" type="number" value="{{difficulty}}" bindinput="onDifficultyInput" />
      </view>
      <view class="filter-item half">
        <text class="filter-label">题量</text>
        <slider min="1" max="20" step="1" value="{{limit}}" show-value bindchange="onLimitChange" />
      </view>
    </view>
  </view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>

  <view wx:if="{{questions.length === 0 && !loading}}" class="empty">
    暂无可练习题目，请检查学科映射或筛选条件
  </view>

  <block wx:for="{{questions}}" wx:key="id">
    <view class="card">
      <text class="stem">{{index + 1}}. {{item.stem}}</text>
      <text class="meta">题型：{{item.questionType === 'single' ? '单选' : '多选'}}</text>

      <block wx:for="{{item.options}}" wx:for-item="opt" wx:key="letter">
        <view
          class="option {{util.hasLetter(answers[item.id], opt.letter) ? 'option-selected' : ''}}"
          data-question-id="{{item.id}}"
          data-letter="{{opt.letter}}"
          bindtap="onSelectOption"
        >
          <text class="option-letter">{{opt.letter}}.</text>
          <text class="option-text">{{opt.text}}</text>
        </view>
      </block>
    </view>
  </block>

  <button
    class="submit-btn"
    type="primary"
    loading="{{submitting}}"
    disabled="{{questions.length === 0 || submitting || !sessionId}}"
    bindtap="onSubmit"
  >
    提交并判分
  </button>

  <view wx:if="{{result}}" class="result">
    <text class="result-title">得分：{{result.correct}} / {{result.total}}</text>
    <button class="go-wrong-btn" size="mini" bindtap="goWrongBook">查看错题本</button>
    <block wx:for="{{result.details}}" wx:key="questionId">
      <view class="result-item {{item.isCorrect ? 'ok' : 'bad'}}">
        <text>第{{index + 1}}题：{{item.isCorrect ? '正确' : '错误'}}</text>
        <text wx:if="{{!item.isCorrect}}">
          你的答案：{{util.formatSelected(item.selectedLetters)}}；正确答案：{{util.joinLetters(item.correctLetters, ',')}}
        </text>
        <text wx:if="{{item.analysis}}">解析：{{item.analysis}}</text>
      </view>
    </block>
  </view>
</view>
