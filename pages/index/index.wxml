<wxs module="util">
function hasLetter(selected, letter) {
  if (!selected || selected.length === 0) return false;
  for (var i = 0; i < selected.length; i++) {
    if (selected[i] === letter) return true;
  }
  return false;
}
function joinLetters(arr, sep) {
  if (!arr || arr.length === 0) return '';
  var s = arr[0];
  for (var i = 1; i < arr.length; i++) {
    s = s + sep + arr[i];
  }
  return s;
}
function formatSelected(arr) {
  var j = joinLetters(arr, ',');
  return j ? j : '未作答';
}
module.exports.hasLetter = hasLetter;
module.exports.joinLetters = joinLetters;
module.exports.formatSelected = formatSelected;
</wxs>

<view class="container">
  <view class="assignment-banner" wx:if="{{assignmentMode}}">班级作业 · 请完成全部题目后提交</view>
  <view class="header">
    <text class="title">QuizWiz 练习模式</text>
    <view class="header-actions">
      <button class="history-btn" size="mini" bindtap="goHistory">练习历史</button>
      <button class="class-btn" size="mini" bindtap="goClass">我的班级</button>
      <button class="wrong-btn" size="mini" bindtap="goWrongBook">错题本</button>
      <button class="fav-nav-btn" size="mini" bindtap="goFavorite">收藏</button>
      <button class="refresh-btn" size="mini" bindtap="startPractice" loading="{{starting}}">开始练习</button>
    </view>
  </view>

  <view class="stats-card">
    <text class="stats-hint">统计按服务器日期；仅统计已提交的练习</text>
    <view class="stats-row">
      <view class="stats-cell">
        <text class="stats-label">今日</text>
        <text class="stats-main">{{stats.today.attempted}} 题</text>
        <text class="stats-sub">对 {{stats.today.correct}} · {{stats.today.accuracy}}%</text>
      </view>
      <view class="stats-cell">
        <text class="stats-label">近7日</text>
        <text class="stats-main">{{stats.last7Days.attempted}} 题</text>
        <text class="stats-sub">对 {{stats.last7Days.correct}} · {{stats.last7Days.accuracy}}%</text>
      </view>
      <view class="stats-cell">
        <text class="stats-label">累计</text>
        <text class="stats-main">{{stats.all.attempted}} 题</text>
        <text class="stats-sub">对 {{stats.all.correct}} · {{stats.all.accuracy}}%</text>
      </view>
    </view>
    <view class="stats-by-block" wx:if="{{stats.bySubjectToday.length > 0}}">
      <text class="stats-by-title">今日 · 按学科</text>
      <block wx:for="{{stats.bySubjectToday}}" wx:key="statsKey">
        <view class="stats-by-row">
          <text class="stats-by-name">{{item.subjectName}}</text>
          <text class="stats-by-num">{{item.attempted}}题 · {{item.accuracy}}%</text>
        </view>
      </block>
    </view>
    <view class="stats-by-block" wx:if="{{stats.bySubjectLast7Days.length > 0}}">
      <text class="stats-by-title">近7日 · 按学科</text>
      <block wx:for="{{stats.bySubjectLast7Days}}" wx:key="statsKey">
        <view class="stats-by-row">
          <text class="stats-by-name">{{item.subjectName}}</text>
          <text class="stats-by-num">{{item.attempted}}题 · {{item.accuracy}}%</text>
        </view>
      </block>
    </view>
    <view class="stats-by-block" wx:if="{{stats.bySubjectAll.length > 0}}">
      <text class="stats-by-title">累计 · 按学科</text>
      <block wx:for="{{stats.bySubjectAll}}" wx:key="statsKey">
        <view class="stats-by-row">
          <text class="stats-by-name">{{item.subjectName}}</text>
          <text class="stats-by-num">{{item.attempted}}题 · {{item.accuracy}}%</text>
        </view>
      </block>
    </view>
  </view>

  <view class="report-list-card">
    <view class="report-list-head">
      <text class="report-list-title">我的纠错反馈</text>
      <view class="report-list-actions">
        <picker mode="selector" range="{{reportStatusOptions}}" value="{{reportStatusFilterIndex}}" bindchange="onReportStatusFilterChange">
          <view class="report-filter-picker">{{reportStatusOptions[reportStatusFilterIndex]}}</view>
        </picker>
        <button class="report-refresh-btn" size="mini" bindtap="loadMyReports" loading="{{myReportsLoading}}">刷新</button>
      </view>
    </view>
    <view wx:if="{{myReports.length === 0}}" class="report-list-empty">暂无反馈记录</view>
    <block wx:for="{{myReports}}" wx:key="id">
      <view class="report-item">
        <view class="report-item-row">
          <text class="report-item-status status-{{item.status}}">{{item.statusText}}</text>
          <text class="report-item-reason">{{item.reasonText}}</text>
        </view>
        <text class="report-item-stem">题目#{{item.questionId}}：{{item.stem}}</text>
        <text wx:if="{{item.adminNote}}" class="report-item-note">处理备注：{{item.adminNote}}</text>
      </view>
    </block>
  </view>

  <view class="filters" wx:if="{{!assignmentMode}}">
    <view class="filter-item">
      <text class="filter-label">学科</text>
      <picker mode="selector" range="{{subjects}}" range-key="name" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-view">{{subjects.length > 0 ? subjects[subjectIndex].name : '暂无学科'}}</view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="filter-label">章节</text>
      <input class="input" placeholder="可选，多个用逗号分隔" value="{{chapterInput}}" bindinput="onChapterInput" />
    </view>
    <view class="filter-item" wx:if="{{!practiceModeLocked}}">
      <text class="filter-label">出题方式</text>
      <picker mode="selector" range="{{practiceModeLabels}}" value="{{practiceModePickerIndex}}" bindchange="onPracticeModeChange">
        <view class="picker-view">{{practiceModeLabels[practiceModePickerIndex]}}</view>
      </picker>
    </view>
    <view class="filter-row">
      <view class="filter-item half">
        <text class="filter-label">难度(1-5)</text>
        <input class="input" type="number" value="{{difficulty}}" bindinput="onDifficultyInput" />
      </view>
      <view class="filter-item half">
        <text class="filter-label">题量</text>
        <slider min="1" max="20" step="1" value="{{limit}}" show-value bindchange="onLimitChange" />
      </view>
    </view>
    <text class="filter-hint" wx:if="{{!practiceModeLocked}}">计时：从首次选择选项起算到提交；未作答题目不计时。</text>
  </view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>

  <view wx:if="{{questions.length === 0 && !loading}}" class="empty">
    {{emptyHint || '暂无可练习题目，请检查学科映射或筛选条件'}}
  </view>

  <block wx:for="{{questions}}" wx:key="id">
    <view class="card">
      <view class="card-head">
        <text class="stem-text stem-in-card">{{index + 1}}. {{item.stem}}</text>
        <view class="card-head-right">
          <text class="report-link" data-id="{{item.id}}" catchtap="openReport">纠错</text>
          <view class="fav-tap" data-id="{{item.id}}" catchtap="onToggleFavorite">
            <text class="fav-icon">{{item.isFavorite ? '★' : '☆'}}</text>
          </view>
        </view>
      </view>
      <text class="meta">题型：{{item.questionType === 'single' ? '单选' : '多选'}}</text>

      <block wx:for="{{item.options}}" wx:for-item="opt" wx:key="letter">
        <view
          class="option {{util.hasLetter(answers[item.id], opt.letter) ? 'option-selected' : ''}}"
          data-question-id="{{item.id}}"
          data-letter="{{opt.letter}}"
          bindtap="onSelectOption"
        >
          <text class="option-letter">{{opt.letter}}.</text>
          <text class="option-text">{{opt.text}}</text>
        </view>
      </block>
    </view>
  </block>

  <button
    class="submit-btn"
    type="primary"
    loading="{{submitting}}"
    disabled="{{questions.length === 0 || submitting || !sessionId}}"
    bindtap="onSubmit"
  >
    提交并判分
  </button>

  <view wx:if="{{result}}" class="result">
    <text class="result-title">得分：{{result.correct}} / {{result.total}}</text>
    <text wx:if="{{result.totalCostSecText}}" class="result-time">用时（已计时题目）：约 {{result.totalCostSecText}} 秒</text>
    <button class="go-wrong-btn" size="mini" bindtap="goWrongBook">查看错题本</button>
    <block wx:for="{{result.details}}" wx:key="questionId">
      <view class="result-item {{item.isCorrect ? 'ok' : 'bad'}}">
        <text>第{{index + 1}}题：{{item.isCorrect ? '正确' : '错误'}}</text>
        <text wx:if="{{!item.isCorrect}}">
          你的答案：{{util.formatSelected(item.selectedLetters)}}；正确答案：{{util.joinLetters(item.correctLetters, ',')}}
        </text>
        <text wx:if="{{item.analysis}}">解析：{{item.analysis}}</text>
      </view>
    </block>
  </view>

  <view class="report-mask" wx:if="{{reportShow}}" catchtouchmove="preventMove" bindtap="closeReport">
    <view class="report-dialog" catchtap="preventMove">
      <text class="report-title">题目纠错</text>
      <picker mode="selector" range="{{reportReasons}}" range-key="label" value="{{reportReasonIndex}}" bindchange="onReportReasonChange">
        <view class="report-picker">{{reportReasons[reportReasonIndex].label}}</view>
      </picker>
      <textarea class="report-textarea" placeholder="补充说明（可选，最多500字）" value="{{reportDetail}}" maxlength="500" bindinput="onReportDetailInput" />
      <view class="report-actions">
        <button size="mini" bindtap="closeReport">取消</button>
        <button size="mini" type="primary" bindtap="submitReport">提交</button>
      </view>
    </view>
  </view>
</view>
