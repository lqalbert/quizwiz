/* 我的班级 */

.page {
  padding: 40rpx;
  min-height: 100vh;
  background: #f8f9fb;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.hint {
  display: block;
  font-size: 28rpx;
  color: #757575;
  margin-bottom: 24rpx;
  line-height: 1.55;
}

.input {
  border: 1rpx solid #e8eaed;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
  background: #f3f5f8;
  color: #1a1a1a;
  box-sizing: border-box;
}

.btn.primary {
  background: #0066ff !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  font-weight: 600 !important;
  font-size: 30rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  box-shadow: 0 12rpx 28rpx rgba(0, 102, 255, 0.25);
}

.btn.primary::after {
  border: none !important;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 20rpx;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}

.muted {
  color: #9e9e9e;
  font-size: 26rpx;
}

.mine-row {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef0f4;
}

.mine-row:last-child {
  border-bottom: none;
}

.mine-name {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.mine-sub {
  display: block;
  font-size: 24rpx;
  color: #757575;
  margin-top: 8rpx;
}

.hw-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef0f4;
}

.hw-row:last-child {
  border-bottom: none;
}

.hw-main {
  flex: 1;
  min-width: 0;
}

.hw-title {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.4;
}

.hw-sub,
.hw-due {
  display: block;
  font-size: 24rpx;
  color: #757575;
  margin-top: 8rpx;
}

.hw-overdue {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #d92d20;
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: #fef3f2;
  border-radius: 999rpx;
}

.hw-done {
  display: inline-block;
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #0d7a3b;
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: #e8f8ef;
  border-radius: 999rpx;
}

.hw-btn {
  flex-shrink: 0;
  margin: 0 !important;
  background: #0066ff !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  font-weight: 600 !important;
  border: none !important;
}

.hw-btn::after {
  border: none !important;
}
