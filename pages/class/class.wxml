<view class="page">
  <view class="card">
    <text class="hint">向老师索取 8 位邀请码，输入后加入班级。</text>
    <input
      class="input"
      type="text"
      maxlength="16"
      placeholder="邀请码"
      value="{{inviteInput}}"
      bindinput="onInviteInput"
    />
    <button class="btn primary" loading="{{joining}}" bindtap="joinClass">加入班级</button>
  </view>

  <view class="card">
    <text class="section-title">已加入的班级</text>
    <view wx:if="{{loading}}" class="muted">加载中…</view>
    <view wx:elif="{{mine.length === 0}}" class="muted">暂无，请先加入班级</view>
    <block wx:else>
      <view class="mine-row" wx:for="{{mine}}" wx:key="classId">
        <text class="mine-name">{{item.className}}</text>
        <text class="mine-sub">加入于 {{item.joinedAt}}</text>
      </view>
    </block>
  </view>

  <view class="card">
    <text class="section-title">班级作业</text>
    <view wx:if="{{assignmentsLoading}}" class="muted">加载中…</view>
    <view wx:elif="{{assignments.length === 0}}" class="muted">暂无作业（需先加入班级）</view>
    <block wx:else>
      <view class="hw-row" wx:for="{{assignments}}" wx:key="assignmentId">
        <view class="hw-main">
          <text class="hw-title">{{item.title}}</text>
          <text class="hw-sub">{{item.className}} · 共 {{item.questionCount}} 题</text>
          <text wx:if="{{item.dueAt}}" class="hw-due">截止 {{item.dueAt}}</text>
          <text wx:if="{{item.overdue}}" class="hw-overdue">已逾期</text>
          <text wx:if="{{item.completed}}" class="hw-done">已完成</text>
        </view>
        <button class="hw-btn" size="mini" data-id="{{item.assignmentId}}" bindtap="goDoAssignment">
          {{item.completed ? '再做一次' : '去完成'}}
        </button>
      </view>
    </block>
  </view>
</view>
